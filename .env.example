# =====================================================================
# Bagnoli Monitor — Environment
# =====================================================================
# Copia in `.env` (non commitare).

# Connessione al PostgreSQL sul server aaPanel (cluster 17, porta 5434)
# Dev locale (via SSH tunnel): vedi sezione dev nel README
# Container in produzione sul server: usa host.docker.internal:5434
DATABASE_URL="postgresql://bagnoli_ro:PASSWORD@host.docker.internal:5434/bagnoli?schema=bagnoli"

# URL pubblica
NEXT_PUBLIC_SITE_URL="https://monitoraggio.analist24.it.com"

# Porta interna del container Next.js
PORT=3000
