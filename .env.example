# ============================================================
# Bagnoli Monitor – variabili d'ambiente (template)
# Copiare in ".env" (NON committare) e compilare i valori
# ============================================================

# -- Database PostgreSQL (Hetzner in prod, locale in dev) ----
# Prod: fornita da admin, schema bagnoli_cantieri
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# -- URL pubblico dell'app (per metadata OpenGraph / canonicali) ---
NEXT_PUBLIC_SITE_URL=https://monitoraggio.analist24.it.com

# -- Runtime Next.js ----------------------------------------
PORT=3000
NODE_ENV=production

# -- Area riservata /admin ----------------------------------
ADMIN_USER=admin
ADMIN_PASS=CHANGE_ME

# Secret per firma cookie sessione (HMAC SHA-256).
# Generarne uno nuovo con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# oppure:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=CHANGE_ME_TO_64_HEX_CHARS

# -- Profilo dev opzionale (docker compose --profile dev up) ----
# Password per il Postgres locale in db-dev
DB_DEV_PASSWORD=dev_password_change_me
